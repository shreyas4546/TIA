{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "User's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "photoURL": {
          "type": "string",
          "description": "Optional URL to user's profile picture"
        },
        "preferences": {
          "type": "object",
          "description": "User preferences",
          "properties": {
            "theme": { "type": "string", "enum": ["light", "dark", "system"] },
            "notifications": { "type": "boolean" },
            "currency": { "type": "string" }
          }
        },
        "linkedInstitutions": {
          "type": "array",
          "description": "List of linked financial institutions",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": { "type": "string" },
              "status": { "type": "string", "enum": ["active", "error", "syncing"] },
              "lastSynced": { "type": "string", "format": "date-time" }
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when user was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when user was last updated"
        }
      },
      "required": ["email", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    }
  }
}
